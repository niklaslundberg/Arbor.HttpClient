<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Arbor.HttpClient.Desktop.Features.Options"
             xmlns:loc="using:Arbor.HttpClient.Desktop.Localization"
             x:Class="Arbor.HttpClient.Desktop.Features.Options.DiagnosticsOptionsPageView"
             x:DataType="vm:OptionsViewModel">
  <StackPanel Spacing="20">
    <CheckBox IsChecked="{Binding App.CollectUnhandledExceptions, Mode=TwoWay}"
              Content="{x:Static loc:Strings.OptionsCollectExceptions}" />

    <TextBlock Text="{x:Static loc:Strings.OptionsCollectExceptionsDescription}"
               TextWrapping="Wrap"
               Opacity="0.65"
               FontSize="11" />

    <Button Content="{x:Static loc:Strings.OptionsViewCollectedExceptions}"
            AutomationProperties.Name="{x:Static loc:Strings.OptionsViewCollectedExceptions}"
            Command="{Binding App.OpenDiagnosticsCommand}" />
  </StackPanel>
</UserControl>

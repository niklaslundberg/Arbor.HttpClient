<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:webview="using:Avalonia.Controls"
        x:Class="Arbor.HttpClient.Desktop.Features.WebView.WebViewWindow"
        Title="Web View"
        Width="1024"
        Height="720"
        MinWidth="480"
        MinHeight="320">

    <Grid RowDefinitions="Auto,*">

        <!-- Navigation bar -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button x:Name="BackButton"
                        Content="←"
                        Width="32"
                        AutomationProperties.Name="Go back"
                        ToolTip.Tip="Go back"
                        IsEnabled="False" />
                <Button x:Name="ForwardButton"
                        Content="→"
                        Width="32"
                        AutomationProperties.Name="Go forward"
                        ToolTip.Tip="Go forward"
                        IsEnabled="False" />
                <Button x:Name="RefreshButton"
                        Content="↺"
                        Width="32"
                        AutomationProperties.Name="Refresh page"
                        ToolTip.Tip="Refresh" />
                <TextBox x:Name="UrlBox"
                         MinWidth="360"
                         HorizontalAlignment="Stretch"
                         AutomationProperties.Name="URL"
                         ToolTip.Tip="Enter a URL and press Enter or click Go" />
                <Button x:Name="GoButton"
                        Content="Go"
                        AutomationProperties.Name="Navigate to URL"
                        ToolTip.Tip="Navigate to the URL" />
            </StackPanel>
        </Border>

        <!-- Embedded native web browser -->
        <webview:NativeWebView x:Name="WebView" Grid.Row="1" />

    </Grid>
</Window>

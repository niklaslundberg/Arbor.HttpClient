<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Arbor.HttpClient.Desktop.ViewModels"
             xmlns:conv="using:Arbor.HttpClient.Desktop.Converters"
             xmlns:aedit="using:AvaloniaEdit"
             xmlns:views="using:Arbor.HttpClient.Desktop.Views"
             x:Class="Arbor.HttpClient.Desktop.Views.RequestView"
             x:CompileBindings="False">

    <UserControl.Resources>
        <conv:MethodToColorConverter x:Key="MethodToColorConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10" Margin="8">

        <Grid.KeyBindings>
            <!-- Standard across Hoppscotch / Insomnia / Postman: Ctrl+Enter (or Cmd+Enter) sends the request -->
            <KeyBinding Gesture="Ctrl+Return" Command="{Binding App.SendRequestCommand}" />
            <KeyBinding Gesture="Cmd+Return" Command="{Binding App.SendRequestCommand}" />
        </Grid.KeyBindings>

        <Grid ColumnDefinitions="120,*,120" ColumnSpacing="8">
            <TextBox Grid.Column="0" PlaceholderText="Request name"
                     Text="{Binding App.RequestEditor.RequestName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Unified composer: method + URL + Send are rendered as one seamless control
                 (Hoppscotch / Insomnia style). Wrap them in a single Border and strip
                 the inner corners so they visually butt up against each other. -->
            <Border Grid.Column="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1"
                    CornerRadius="3"
                    Background="{DynamicResource SurfaceBackgroundBrush}"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="Auto,Auto,*">
                    <ComboBox Grid.Column="0" MinWidth="100"
                              BorderThickness="0"
                              CornerRadius="0"
                              Background="Transparent"
                              ItemsSource="{Binding App.RequestEditor.Methods}"
                              SelectedItem="{Binding App.RequestEditor.SelectedMethod, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="{Binding Converter={StaticResource MethodToColorConverter}}"
                                           FontWeight="SemiBold" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Rectangle Grid.Column="1" Width="1" VerticalAlignment="Stretch"
                               Fill="{DynamicResource PanelBorderBrush}" />
                    <Grid Grid.Column="2">
                        <aedit:TextEditor x:Name="RequestUrlEditor"
                                          ShowLineNumbers="False"
                                          WordWrap="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Padding="8,6,5,6"
                                          Background="Transparent" />
                        <!-- Placeholder overlay: AvaloniaEdit.TextEditor has no native PlaceholderText,
                             so we render one in parallel that hides as soon as the URL has any content. -->
                        <TextBlock Text="Enter request URL"
                                   IsHitTestVisible="False"
                                   Opacity="0.5"
                                   Padding="10,6,5,6"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding App.RequestEditor.RequestUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                    </Grid>
                </Grid>
            </Border>

            <Button x:Name="SendButton" Grid.Column="2" Content="Send"
                    Classes="accent"
                    HorizontalContentAlignment="Center"
                    HorizontalAlignment="Stretch"
                    ToolTip.Tip="Send request (Ctrl+Enter)"
                    Command="{Binding App.SendRequestCommand}" />
        </Grid>

        <CheckBox Grid.Row="1" Content="Follow redirects"
                  IsChecked="{Binding App.RequestEditor.FollowRedirectsForRequest, Mode=TwoWay}" />

        <TextBlock Grid.Row="2" Text="{Binding App.ErrorMessage}" Foreground="{DynamicResource ErrorBrush}" />

        <TabControl Grid.Row="3">
            <TabItem Header="Query">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,*" RowSpacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Query parameters" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="+ Add Query"
                                Command="{Binding App.RequestEditor.AddQueryParameterCommand}" />
                    </Grid>

                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding App.RequestEditor.RequestQueryParameters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RequestQueryParameterViewModel">
                                    <Grid ColumnDefinitions="Auto,*,*,*,Auto" ColumnSpacing="6" Margin="0,2,0,0">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center" />
                                        <views:VariableTextBox Grid.Column="1" PlaceholderText="Key"
                                                 AppViewModel="{Binding $parent[UserControl].DataContext.App}"
                                                 Text="{Binding Key, Mode=TwoWay}" />
                                        <views:VariableTextBox Grid.Column="2" PlaceholderText="Value"
                                                 AppViewModel="{Binding $parent[UserControl].DataContext.App}"
                                                 Text="{Binding Value, Mode=TwoWay}" />
                                        <TextBox Grid.Column="3" PlaceholderText="Description"
                                                 Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="4" Content="✕"
                                                Command="{Binding $parent[UserControl].DataContext.RemoveQueryParameterCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Body">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Request Body" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Open in editor"
                                Command="{Binding App.OpenRequestBodyInExternalEditorCommand}" />
                    </Grid>
                    <Border Grid.Row="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <aedit:TextEditor x:Name="RequestBodyEditor"
                                          ShowLineNumbers="True"
                                          WordWrap="True"
                                          MinHeight="150" />
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Headers">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,*" RowSpacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Headers" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="+ Add Header"
                                Command="{Binding App.RequestEditor.AddHeaderCommand}" />
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="110,*,*" ColumnSpacing="6">
                        <TextBlock Text="Content-Type" VerticalAlignment="Center" Opacity="0.8" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding App.RequestEditor.ContentTypeOptions}"
                                  SelectedItem="{Binding App.RequestEditor.SelectedContentTypeOption, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch" />
                        <TextBox Grid.Column="2"
                                 PlaceholderText="e.g. application/vnd.api+json"
                                 Text="{Binding App.RequestEditor.CustomContentType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsVisible="{Binding App.RequestEditor.IsCustomContentType}" />
                    </Grid>

                    <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding App.RequestEditor.RequestHeaders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RequestHeaderViewModel">
                                    <Grid ColumnDefinitions="Auto,*,*,*,Auto" ColumnSpacing="6" Margin="0,2,0,0">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center" />
                                        <views:VariableTextBox Grid.Column="1" PlaceholderText="Key"
                                                 AppViewModel="{Binding $parent[UserControl].DataContext.App}"
                                                 Text="{Binding Name, Mode=TwoWay}" />
                                        <views:VariableTextBox Grid.Column="2" PlaceholderText="Value"
                                                 AppViewModel="{Binding $parent[UserControl].DataContext.App}"
                                                 Text="{Binding Value, Mode=TwoWay}" />
                                        <TextBox Grid.Column="3" PlaceholderText="Description"
                                                 Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="4" Content="✕"
                                                Command="{Binding $parent[UserControl].DataContext.RemoveHeaderCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Auth">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="8">
                    <Grid ColumnDefinitions="130,*" ColumnSpacing="8">
                        <TextBlock Text="Type" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding App.RequestEditor.AuthModeOptions}"
                                  SelectedItem="{Binding App.RequestEditor.SelectedAuthModeOption, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="130,*" ColumnSpacing="8"
                          IsVisible="{Binding App.RequestEditor.IsBearerAuthMode}">
                        <TextBlock Text="Token" VerticalAlignment="Center" />
                        <views:VariableTextBox Grid.Column="1" PlaceholderText="Bearer token"
                                               AppViewModel="{Binding App}"
                                               Text="{Binding App.RequestEditor.AuthBearerToken, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="130,*" ColumnSpacing="8"
                          IsVisible="{Binding App.RequestEditor.IsBasicAuthMode}">
                        <TextBlock Text="Username" VerticalAlignment="Center" />
                        <views:VariableTextBox Grid.Column="1" PlaceholderText="Username"
                                               AppViewModel="{Binding App}"
                                               Text="{Binding App.RequestEditor.AuthBasicUsername, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Row="3" ColumnDefinitions="130,*" ColumnSpacing="8"
                          IsVisible="{Binding App.RequestEditor.IsBasicAuthMode}">
                        <TextBlock Text="Password" VerticalAlignment="Center" />
                        <views:VariableTextBox Grid.Column="1" PlaceholderText="Password"
                                               AppViewModel="{Binding App}"
                                               Text="{Binding App.RequestEditor.AuthBasicPassword, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Row="4" ColumnDefinitions="130,*" ColumnSpacing="8"
                          IsVisible="{Binding App.RequestEditor.IsApiKeyAuthMode}">
                        <TextBlock Text="API key" VerticalAlignment="Center" />
                        <views:VariableTextBox Grid.Column="1" PlaceholderText="API key"
                                               AppViewModel="{Binding App}"
                                               Text="{Binding App.RequestEditor.AuthApiKey, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Row="5" ColumnDefinitions="130,*" ColumnSpacing="8"
                          IsVisible="{Binding App.RequestEditor.IsOAuth2ClientCredentialsAuthMode}">
                        <TextBlock Text="Access token" VerticalAlignment="Center" />
                        <views:VariableTextBox Grid.Column="1" PlaceholderText="OAuth 2 access token"
                                               AppViewModel="{Binding App}"
                                               Text="{Binding App.RequestEditor.AuthOAuth2AccessToken, Mode=TwoWay}" />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Preview">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,*">
                    <TextBlock Text="Rendered request (as sent)" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Grid.Row="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <aedit:TextEditor x:Name="RequestPreviewEditor"
                                          IsReadOnly="True"
                                          ShowLineNumbers="True"
                                          WordWrap="True"
                                          MinHeight="150" />
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Arbor.HttpClient.Desktop.ViewModels"
             xmlns:conv="using:Arbor.HttpClient.Desktop.Converters"
             xmlns:aedit="using:AvaloniaEdit"
             x:Class="Arbor.HttpClient.Desktop.Views.RequestView"
             x:CompileBindings="False">

    <UserControl.Resources>
        <conv:MethodToColorConverter x:Key="MethodToColorConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10" Margin="8">

        <Grid ColumnDefinitions="120,Auto,*,120" ColumnSpacing="8">
            <TextBox Grid.Column="0" PlaceholderText="Request name"
                     Text="{Binding App.RequestName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox Grid.Column="1" MinWidth="100"
                      ItemsSource="{Binding App.Methods}"
                      SelectedItem="{Binding App.SelectedMethod, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   Foreground="{Binding Converter={StaticResource MethodToColorConverter}}"
                                   FontWeight="SemiBold" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Border Grid.Column="2" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                <aedit:TextEditor x:Name="RequestUrlEditor"
                                  ShowLineNumbers="False"
                                  WordWrap="False"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Hidden"
                                  MinHeight="32" />
            </Border>
            <Button x:Name="SendButton" Grid.Column="3" Content="Send"
                    Command="{Binding App.SendRequestCommand}" />
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding App.ErrorMessage}" Foreground="{DynamicResource ErrorBrush}" />

        <TabControl Grid.Row="2">
            <TabItem Header="Query">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,*" RowSpacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Query parameters" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="+ Add Query"
                                Command="{Binding App.AddQueryParameterCommand}" />
                    </Grid>

                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding App.RequestQueryParameters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RequestQueryParameterViewModel">
                                    <Grid ColumnDefinitions="Auto,*,*,*,Auto" ColumnSpacing="6" Margin="0,2,0,0">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" PlaceholderText="Key"
                                                 Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="2" PlaceholderText="Value"
                                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="3" PlaceholderText="Description"
                                                 Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="4" Content="✕"
                                                Command="{Binding $parent[UserControl].DataContext.RemoveQueryParameterCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Body">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Request Body" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Open in editor"
                                Command="{Binding App.OpenRequestBodyInExternalEditorCommand}" />
                    </Grid>
                    <Border Grid.Row="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <aedit:TextEditor x:Name="RequestBodyEditor"
                                          ShowLineNumbers="True"
                                          WordWrap="True"
                                          MinHeight="150" />
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Headers">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,*" RowSpacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Headers" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="+ Add Header"
                                Command="{Binding App.AddHeaderCommand}" />
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="110,*,*" ColumnSpacing="6">
                        <TextBlock Text="Content-Type" VerticalAlignment="Center" Opacity="0.8" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding App.ContentTypeOptions}"
                                  SelectedItem="{Binding App.SelectedContentTypeOption, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch" />
                        <TextBox Grid.Column="2"
                                 PlaceholderText="e.g. application/vnd.api+json"
                                 Text="{Binding App.CustomContentType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsVisible="{Binding App.IsCustomContentType}" />
                    </Grid>

                    <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding App.RequestHeaders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RequestHeaderViewModel">
                                    <Grid ColumnDefinitions="Auto,*,*,*,Auto" ColumnSpacing="6" Margin="0,2,0,0">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" PlaceholderText="Key"
                                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="2" PlaceholderText="Value"
                                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="3" PlaceholderText="Description"
                                                 Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="4" Content="✕"
                                                Command="{Binding $parent[UserControl].DataContext.RemoveHeaderCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Preview">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,*">
                    <TextBlock Text="Rendered request (as sent)" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Grid.Row="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <aedit:TextEditor x:Name="RequestPreviewEditor"
                                          IsReadOnly="True"
                                          ShowLineNumbers="True"
                                          WordWrap="True"
                                          MinHeight="150" />
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Arbor.HttpClient.Desktop.App"
             xmlns:local="using:Arbor.HttpClient.Desktop"
             xmlns:dock="using:Dock.Avalonia.Themes.Fluent"
             RequestedThemeVariant="Default">
    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="AppFontFamily">Cascadia Code,Consolas,Menlo,monospace</FontFamily>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="OptionsNavBackgroundBrush" Color="#2D2D30" />
                    <SolidColorBrush x:Key="TopToolbarBorderBrush" Color="#2A2A2A" />
                    <SolidColorBrush x:Key="SecondaryPanelBackgroundBrush" Color="#1A1A2E" />
                    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#12212F" />
                    <SolidColorBrush x:Key="PreviewPanelBackgroundBrush" Color="#0D1B2A" />
                    <SolidColorBrush x:Key="PanelBorderBrush" Color="#3C3F41" />
                    <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="#1E1E1E" />
                    <SolidColorBrush x:Key="CollectionSelectionBrush" Color="#1E3A5F" />
                    <SolidColorBrush x:Key="MethodFallbackBrush" Color="#F5F5F5" />
                    <SolidColorBrush x:Key="ErrorBrush" Color="#FF6347" />
                    <SolidColorBrush x:Key="WarningBrush" Color="#FFB74D" />
                    <!-- Method label colors: accessible against dark backgrounds (WCAG AA ≥ 4.5:1 on #1E1E1E) -->
                    <SolidColorBrush x:Key="MethodGetBrush" Color="#4FC3F7" />
                    <SolidColorBrush x:Key="MethodPostBrush" Color="#6FCF97" />
                    <SolidColorBrush x:Key="MethodPutBrush" Color="#FFB74D" />
                    <SolidColorBrush x:Key="MethodPatchBrush" Color="#CE93D8" />
                    <SolidColorBrush x:Key="MethodDeleteBrush" Color="#EF5350" />
                    <!-- HTTP response status colors (by family) — contrast-verified against dark surfaces -->
                    <SolidColorBrush x:Key="StatusInformationalBrush" Color="#4FC3F7" />
                    <SolidColorBrush x:Key="StatusSuccessBrush" Color="#6FCF97" />
                    <SolidColorBrush x:Key="StatusRedirectBrush" Color="#4FC3F7" />
                    <SolidColorBrush x:Key="StatusClientErrorBrush" Color="#FFB74D" />
                    <SolidColorBrush x:Key="StatusServerErrorBrush" Color="#EF5350" />
                    <!-- Variable token colors: brackets {{ }} amber, name violet -->
                    <SolidColorBrush x:Key="VariableBracketBrush" Color="#FFB74D" />
                    <SolidColorBrush x:Key="VariableNameBrush" Color="#CE93D8" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="OptionsNavBackgroundBrush" Color="#F0F0F0" />
                    <SolidColorBrush x:Key="TopToolbarBorderBrush" Color="#D0D7DE" />
                    <SolidColorBrush x:Key="SecondaryPanelBackgroundBrush" Color="#F5F8FC" />
                    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F3F6FA" />
                    <SolidColorBrush x:Key="PreviewPanelBackgroundBrush" Color="#EEF4FA" />
                    <SolidColorBrush x:Key="PanelBorderBrush" Color="#C5D0DB" />
                    <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="CollectionSelectionBrush" Color="#DCEBFF" />
                    <SolidColorBrush x:Key="MethodFallbackBrush" Color="#1F2328" />
                    <SolidColorBrush x:Key="ErrorBrush" Color="#B42318" />
                    <SolidColorBrush x:Key="WarningBrush" Color="#875F09" />
                    <!-- Method label colors: accessible against light backgrounds (WCAG AA ≥ 4.5:1 on #FFFFFF) -->
                    <SolidColorBrush x:Key="MethodGetBrush" Color="#0065BD" />
                    <SolidColorBrush x:Key="MethodPostBrush" Color="#107C10" />
                    <SolidColorBrush x:Key="MethodPutBrush" Color="#875F09" />
                    <SolidColorBrush x:Key="MethodPatchBrush" Color="#744DA9" />
                    <SolidColorBrush x:Key="MethodDeleteBrush" Color="#C50F1F" />
                    <!-- HTTP response status colors (by family) — contrast-verified against light surfaces -->
                    <SolidColorBrush x:Key="StatusInformationalBrush" Color="#0065BD" />
                    <SolidColorBrush x:Key="StatusSuccessBrush" Color="#107C10" />
                    <SolidColorBrush x:Key="StatusRedirectBrush" Color="#0065BD" />
                    <SolidColorBrush x:Key="StatusClientErrorBrush" Color="#875F09" />
                    <SolidColorBrush x:Key="StatusServerErrorBrush" Color="#C50F1F" />
                    <!-- Variable token colors: brackets {{ }} amber, name violet -->
                    <SolidColorBrush x:Key="VariableBracketBrush" Color="#875F09" />
                    <SolidColorBrush x:Key="VariableNameBrush" Color="#744DA9" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <dock:DockFluentTheme />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
        <Style Selector="TextBox">
            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        </Style>
    </Application.Styles>
</Application>

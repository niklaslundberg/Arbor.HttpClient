<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Arbor.HttpClient.Desktop.ViewModels"
             xmlns:models="using:Arbor.HttpClient.Core.Models"
             x:Class="Arbor.HttpClient.Desktop.Views.EnvironmentsView"
             x:DataType="vm:EnvironmentsViewModel">

    <Grid Margin="12" RowDefinitions="Auto,*,Auto" RowSpacing="10">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBlock Text="Manage environments"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Content="+ New Environment"
                    Command="{Binding App.NewEnvironmentCommand}" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8">
                <ItemsControl ItemsSource="{Binding App.Environments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:RequestEnvironment">
                            <Border BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <Border Background="{DynamicResource CollectionSelectionBrush}"
                                                CornerRadius="10"
                                                Padding="6,1">
                                            <TextBlock Text="{Binding Variables.Count, StringFormat='{}{0} vars'}"
                                                       FontSize="11" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                        <Button Content="Edit"
                                                Command="{Binding $parent[UserControl].DataContext.App.EditEnvironmentCommand}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="Delete"
                                                Command="{Binding $parent[UserControl].DataContext.App.DeleteEnvironmentCommand}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="6">
                        <TextBlock Text="Environment name" FontWeight="SemiBold" />
                        <TextBox Grid.Row="1"
                                 PlaceholderText="Environment name"
                                 Text="{Binding App.NewEnvironmentName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,*,Auto" ColumnSpacing="8" Margin="0,4,0,0">
                            <TextBlock Text="Active" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Variable key" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Variable value" FontWeight="SemiBold" />
                        </Grid>

                        <ItemsControl Grid.Row="3" ItemsSource="{Binding App.ActiveEnvironmentVariables}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:EnvironmentVariableViewModel">
                                    <Grid ColumnDefinitions="Auto,*,*,Auto" ColumnSpacing="8" Margin="0,2">
                                        <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1"
                                                 PlaceholderText="Variable key"
                                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="2"
                                                 PlaceholderText="Variable value"
                                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="3"
                                                Content="✕"
                                                Command="{Binding $parent[UserControl].DataContext.App.RemoveEnvironmentVariableCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="6">
                            <Button Content="+ Add Variable"
                                    Command="{Binding App.AddEnvironmentVariableCommand}" />
                            <Button Content="Export JSON"
                                    Command="{Binding App.ExportEnvironmentsCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

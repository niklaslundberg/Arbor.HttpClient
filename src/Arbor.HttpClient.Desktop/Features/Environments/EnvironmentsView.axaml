<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Arbor.HttpClient.Desktop.Features.Environments"
             xmlns:models="using:Arbor.HttpClient.Core.Environments"
             xmlns:loc="using:Arbor.HttpClient.Desktop.Localization"
             xmlns:shared="using:Arbor.HttpClient.Desktop.Shared"
             x:Class="Arbor.HttpClient.Desktop.Features.Environments.EnvironmentsView"
             x:DataType="vm:EnvironmentsViewModel">

    <UserControl.Resources>
        <vm:HexColorToBrushConverter x:Key="HexColorToBrushConverter" />
        <shared:NotNullConverter x:Key="NotNullConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.ColorSwatch">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="12" RowDefinitions="Auto,*,Auto" RowSpacing="10">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBlock Text="{x:Static loc:Strings.EnvironmentsTitle}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Content="{x:Static loc:Strings.EnvironmentsNewButton}"
                    Command="{Binding NewEnvironmentCommand}" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8">
                <ItemsControl ItemsSource="{Binding Environments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:RequestEnvironment">
                            <Border BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <!-- Color dot indicator (Pattern C) -->
                                        <Ellipse Width="10" Height="10"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding AccentColor, Converter={StaticResource HexColorToBrushConverter}}"
                                                 IsVisible="{Binding AccentColor, Converter={StaticResource NotNullConverter}}" />
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <Border Background="{DynamicResource CollectionSelectionBrush}"
                                                CornerRadius="10"
                                                Padding="6,1">
                                            <TextBlock Text="{Binding Variables.Count, StringFormat='{}{0} vars'}"
                                                       FontSize="11" />
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                        <Button Content="{x:Static loc:Strings.EnvironmentsEditButton}"
                                                Command="{Binding $parent[UserControl].DataContext.EditEnvironmentCommand}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="{x:Static loc:Strings.EnvironmentsDeleteButton}"
                                                Command="{Binding $parent[UserControl].DataContext.DeleteEnvironmentCommand}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" RowSpacing="6">
                        <TextBlock Text="{x:Static loc:Strings.EnvironmentsNameLabel}" FontWeight="SemiBold" />
                        <TextBox Grid.Row="1"
                                 PlaceholderText="{x:Static loc:Strings.EnvironmentsNamePlaceholder}"
                                 Text="{Binding NewEnvironmentName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- Color picker row (Pattern C) -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                            <TextBlock Text="{x:Static loc:Strings.EnvironmentsColorLabel}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <!-- None option -->
                            <Button Classes="ColorSwatch"
                                    Background="{DynamicResource SurfaceBackgroundBrush}"
                                    Command="{Binding ClearAccentColorCommand}"
                                    ToolTip.Tip="{x:Static loc:Strings.EnvironmentsColorNone}"
                                    AutomationProperties.Name="{x:Static loc:Strings.EnvironmentsColorNone}">
                                <TextBlock Text="∅" FontSize="13" />
                            </Button>
                            <!-- Red -->
                            <Button Classes="ColorSwatch" Background="{DynamicResource EnvironmentsPresetRedBrush}"
                                    Command="{Binding SetAccentColorCommand}" CommandParameter="#B41E1E"
                                    ToolTip.Tip="{x:Static loc:Strings.EnvironmentsColorAccessibleNameRed}"
                                    AutomationProperties.Name="{x:Static loc:Strings.EnvironmentsColorAccessibleNameRed}" />
                            <!-- Amber -->
                            <Button Classes="ColorSwatch" Background="{DynamicResource EnvironmentsPresetAmberBrush}"
                                    Command="{Binding SetAccentColorCommand}" CommandParameter="#8B5500"
                                    ToolTip.Tip="{x:Static loc:Strings.EnvironmentsColorAccessibleNameAmber}"
                                    AutomationProperties.Name="{x:Static loc:Strings.EnvironmentsColorAccessibleNameAmber}" />
                            <!-- Green -->
                            <Button Classes="ColorSwatch" Background="{DynamicResource EnvironmentsPresetGreenBrush}"
                                    Command="{Binding SetAccentColorCommand}" CommandParameter="#1E7A3C"
                                    ToolTip.Tip="{x:Static loc:Strings.EnvironmentsColorAccessibleNameGreen}"
                                    AutomationProperties.Name="{x:Static loc:Strings.EnvironmentsColorAccessibleNameGreen}" />
                            <!-- Blue -->
                            <Button Classes="ColorSwatch" Background="{DynamicResource EnvironmentsPresetBlueBrush}"
                                    Command="{Binding SetAccentColorCommand}" CommandParameter="#1E50B4"
                                    ToolTip.Tip="{x:Static loc:Strings.EnvironmentsColorAccessibleNameBlue}"
                                    AutomationProperties.Name="{x:Static loc:Strings.EnvironmentsColorAccessibleNameBlue}" />
                            <!-- Purple -->
                            <Button Classes="ColorSwatch" Background="{DynamicResource EnvironmentsPresetPurpleBrush}"
                                    Command="{Binding SetAccentColorCommand}" CommandParameter="#6A1EB4"
                                    ToolTip.Tip="{x:Static loc:Strings.EnvironmentsColorAccessibleNamePurple}"
                                    AutomationProperties.Name="{x:Static loc:Strings.EnvironmentsColorAccessibleNamePurple}" />
                            <!-- Selected color preview dot -->
                            <Ellipse Width="18" Height="18"
                                     VerticalAlignment="Center"
                                     Fill="{Binding EditingAccentColor, Converter={StaticResource HexColorToBrushConverter}}"
                                     IsVisible="{Binding EditingAccentColor, Converter={StaticResource NotNullConverter}}" />
                        </StackPanel>

                        <!-- Warning banner checkbox -->
                        <CheckBox Grid.Row="3"
                                  Content="{x:Static loc:Strings.EnvironmentsShowWarningBanner}"
                                  IsChecked="{Binding EditingShowWarningBanner, Mode=TwoWay}" />

                        <Grid Grid.Row="4" ColumnDefinitions="Auto,*,*,Auto" ColumnSpacing="8" Margin="0,4,0,0">
                            <TextBlock Text="{x:Static loc:Strings.EnvironmentsActiveColumn}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{x:Static loc:Strings.EnvironmentsVariableKeyColumn}" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="{x:Static loc:Strings.EnvironmentsVariableValueColumn}" FontWeight="SemiBold" />
                        </Grid>

                        <ItemsControl Grid.Row="5" ItemsSource="{Binding ActiveEnvironmentVariables}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:EnvironmentVariableViewModel">
                                    <Grid ColumnDefinitions="Auto,*,*,Auto" ColumnSpacing="8" Margin="0,2">
                                        <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1"
                                                 PlaceholderText="{x:Static loc:Strings.EnvironmentsVariableKeyPlaceholder}"
                                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="2"
                                                 PlaceholderText="{x:Static loc:Strings.EnvironmentsVariableValuePlaceholder}"
                                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="3"
                                                Content="✕"
                                                Command="{Binding $parent[UserControl].DataContext.RemoveEnvironmentVariableCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="6">
                            <Button Content="{x:Static loc:Strings.EnvironmentsAddVariable}"
                                    Command="{Binding AddEnvironmentVariableCommand}" />
                            <Button Content="{x:Static loc:Strings.EnvironmentsExportJson}"
                                    Command="{Binding ExportEnvironmentsCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

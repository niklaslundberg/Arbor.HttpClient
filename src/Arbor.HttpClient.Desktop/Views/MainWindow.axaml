<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Arbor.HttpClient.Desktop.ViewModels"
        xmlns:conv="using:Arbor.HttpClient.Desktop.Converters"
        xmlns:models="using:Arbor.HttpClient.Core.Models"
        xmlns:aedit="using:AvaloniaEdit"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1300" d:DesignHeight="820"
        x:Class="Arbor.HttpClient.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Arbor.HttpClient"
        Width="1300"
        Height="820">

    <Window.Resources>
        <conv:MethodToColorConverter x:Key="MethodToColorConverter" />
    </Window.Resources>

    <DockPanel Margin="0">

        <!-- Top toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,10" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Text="Arbor Http Client" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />

                <!-- Environment selector -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="Env:" VerticalAlignment="Center" Opacity="0.7" />
                    <ComboBox MinWidth="160"
                              ItemsSource="{Binding Environments}"
                              SelectedItem="{Binding ActiveEnvironment, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:RequestEnvironment">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <Button Grid.Column="2" Content="Manage Envs" Margin="6,0"
                        Command="{Binding ToggleEnvironmentPanelCommand}" />
                <Button Grid.Column="3" Content="Import OpenAPI"
                        Command="{Binding ImportCollectionCommand}" />
            </Grid>
        </Border>

        <!-- Environment panel (collapsible) -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding IsEnvironmentPanelVisible}"
                Background="#1A1A2E" Padding="16,10" BorderBrush="#3C3F41" BorderThickness="0,0,0,1">
            <Grid RowDefinitions="Auto,Auto,*,Auto" ColumnDefinitions="*,Auto" RowSpacing="6">
                <TextBlock Text="Environments" FontWeight="SemiBold" FontSize="15" />
                <Button Grid.Column="1" Content="+ New Environment"
                        Command="{Binding NewEnvironmentCommand}" />

                <!-- Existing environments list -->
                <ItemsControl Grid.Row="1" Grid.ColumnSpan="2" ItemsSource="{Binding Environments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:RequestEnvironment">
                            <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,2">
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Edit" Margin="4,0"
                                        Command="{Binding $parent[Window].DataContext.EditEnvironmentCommand}"
                                        CommandParameter="{Binding}" />
                                <Button Grid.Column="2" Content="Delete"
                                        Command="{Binding $parent[Window].DataContext.DeleteEnvironmentCommand}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Edit / new environment form -->
                <Border Grid.Row="2" Grid.ColumnSpan="2" Padding="0,8,0,0">
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="6">
                        <TextBox PlaceholderText="Environment name"
                                 Text="{Binding NewEnvironmentName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding ActiveEnvironmentVariables}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:EnvironmentVariableViewModel">
                                    <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="6" Margin="0,2">
                                        <TextBox PlaceholderText="Name"
                                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="1" PlaceholderText="Value"
                                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="2" Content="✕"
                                                Command="{Binding $parent[Window].DataContext.RemoveEnvironmentVariableCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6">
                            <Button Content="+ Add Variable"
                                    Command="{Binding AddEnvironmentVariableCommand}" />
                            <Button Content="Save Environment"
                                    Command="{Binding SaveEnvironmentCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Main content area -->
        <Grid ColumnDefinitions="300,*" Margin="16" ColumnSpacing="16">

            <!-- Left panel: History / Collections tabs -->
            <Grid RowDefinitions="Auto,*">
                <!-- Tab bar -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button Content="History" Command="{Binding ShowHistoryTabCommand}"
                            FontWeight="{Binding LeftPanelTab, Converter={x:Static conv:TabFontWeightConverter.Instance}, ConverterParameter=History}" />
                    <Button Content="Collections" Command="{Binding ShowCollectionsTabCommand}"
                            FontWeight="{Binding LeftPanelTab, Converter={x:Static conv:TabFontWeightConverter.Instance}, ConverterParameter=Collections}" />
                </StackPanel>

                <!-- History tab -->
                <Border Grid.Row="1" Background="#12212F" Padding="12" CornerRadius="8"
                        IsVisible="{Binding LeftPanelTab, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=History}">
                    <Grid RowDefinitions="Auto,*">
                        <TextBox PlaceholderText="Search history…"
                                 Text="{Binding HistorySearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <ListBox x:Name="HistoryList" Grid.Row="1" ItemsSource="{Binding History}" Margin="0,6,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:SavedRequest">
                                    <StackPanel Margin="0,4">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Method}"
                                                   Foreground="{Binding Method, Converter={StaticResource MethodToColorConverter}}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Url}" TextWrapping="Wrap" FontSize="11" Opacity="0.7" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Collections tab -->
                <Border Grid.Row="1" Background="#12212F" Padding="12" CornerRadius="8"
                        IsVisible="{Binding LeftPanelTab, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Collections}">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <!-- Collection selector -->
                        <ComboBox ItemsSource="{Binding Collections}"
                                  SelectedItem="{Binding SelectedCollection, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Collection">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Delete collection button -->
                        <Button Grid.Row="1" Content="Delete Collection" Margin="0,4,0,0"
                                IsVisible="{Binding SelectedCollection, Converter={x:Static conv:NotNullConverter.Instance}}"
                                Command="{Binding DeleteCollectionCommand}"
                                CommandParameter="{Binding SelectedCollection}" />

                        <!-- Endpoint list -->
                        <ListBox Grid.Row="2" Margin="0,6,0,0"
                                 ItemsSource="{Binding CollectionItems}"
                                 SelectionMode="Single">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:CollectionItemViewModel">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6" Margin="0,3">
                                        <TextBlock Text="{Binding Method}"
                                                   Foreground="{Binding Method, Converter={StaticResource MethodToColorConverter}}"
                                                   FontWeight="SemiBold" MinWidth="50" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Path}" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem:selected">
                                    <Setter Property="Background" Value="#1E3A5F" />
                                </Style>
                            </ListBox.Styles>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- Main request/response panel -->
            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,*,Auto,*" RowSpacing="10">

                <!-- URL bar -->
                <Grid ColumnDefinitions="120,Auto,*,120" ColumnSpacing="8">
                    <TextBox Grid.Column="0" PlaceholderText="Request name"
                             Text="{Binding RequestName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox x:Name="MethodComboBox" Grid.Column="1" MinWidth="100"
                              ItemsSource="{Binding Methods}"
                              SelectedItem="{Binding SelectedMethod, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="{Binding Converter={StaticResource MethodToColorConverter}}"
                                           FontWeight="SemiBold" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBox x:Name="RequestUrlTextBox" Grid.Column="2"
                             PlaceholderText="https://api.example.com or {{baseUrl}}/path"
                             Text="{Binding RequestUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button x:Name="SendButton" Grid.Column="3" Content="Send"
                            Command="{Binding SendRequestCommand}" />
                </Grid>

                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="Tomato" />

                <!-- Headers -->
                <Border Grid.Row="2" BorderBrush="#3C3F41" BorderThickness="1" CornerRadius="4" Padding="8,6">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                        <!-- Section title + Add Header button -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Headers" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="+ Add Header"
                                    Command="{Binding AddHeaderCommand}" />
                        </Grid>

                        <!-- Content-Type special row -->
                        <Grid Grid.Row="1" ColumnDefinitions="110,*,*" ColumnSpacing="6">
                            <TextBlock Text="Content-Type" VerticalAlignment="Center" Opacity="0.8" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding ContentTypeOptions}"
                                      SelectedItem="{Binding SelectedContentTypeOption, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch" />
                            <TextBox Grid.Column="2"
                                     PlaceholderText="e.g. application/vnd.api+json"
                                     Text="{Binding CustomContentType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsVisible="{Binding IsCustomContentType}" />
                        </Grid>

                        <!-- Additional headers list -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding RequestHeaders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RequestHeaderViewModel">
                                    <Grid ColumnDefinitions="Auto,*,*,Auto" ColumnSpacing="6" Margin="0,2,0,0">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" PlaceholderText="Name"
                                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Grid.Column="2" PlaceholderText="Value"
                                                 Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="3" Content="✕"
                                                Command="{Binding $parent[Window].DataContext.RemoveHeaderCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Request Body -->
                <Grid Grid.Row="3" RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Request Body" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Open in editor"
                                Command="{Binding OpenRequestBodyInExternalEditorCommand}" />
                    </Grid>
                    <Border Grid.Row="1" BorderBrush="#3C3F41" BorderThickness="1" CornerRadius="4">
                        <aedit:TextEditor x:Name="RequestBodyEditor"
                                          ShowLineNumbers="True"
                                          WordWrap="True"
                                          FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                                          FontSize="13"
                                          MinHeight="150" />
                    </Border>
                </Grid>

                <TextBlock x:Name="ResponseStatusText" Grid.Row="4"
                           Text="{Binding ResponseStatus}" FontWeight="SemiBold" />

                <!-- Response Body -->
                <Grid Grid.Row="5" RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Response Body" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Open in editor"
                                Command="{Binding OpenResponseBodyInExternalEditorCommand}" />
                    </Grid>
                    <Border Grid.Row="1" BorderBrush="#3C3F41" BorderThickness="1" CornerRadius="4">
                        <aedit:TextEditor x:Name="ResponseBodyEditor"
                                          ShowLineNumbers="True"
                                          WordWrap="True"
                                          IsReadOnly="True"
                                          FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                                          FontSize="13"
                                          MinHeight="200" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</Window>

{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET: Debug Desktop App",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: desktop debug",
      "program": "${workspaceFolder}/artifacts/bin/Arbor.HttpClient.Desktop/debug/Arbor.HttpClient.Desktop.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "justMyCode": true,
      "env": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    {
      "name": ".NET: Debug Core Tests",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: solution debug",
      "program": "${workspaceFolder}/artifacts/bin/Arbor.HttpClient.Core.Tests/debug/Arbor.HttpClient.Core.Tests.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "justMyCode": true
    },
    {
      "name": ".NET: Attach to Process",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ],
  "compounds": [
    {
      "name": ".NET: Desktop + Attachable Tests",
      "configurations": [
        ".NET: Debug Desktop App"
      ],
      "stopAll": true
    }
  ]
}

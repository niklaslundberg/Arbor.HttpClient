<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Arbor.HttpClient.Desktop.Features.HttpRequest"
             xmlns:conv="using:Arbor.HttpClient.Desktop.Features.HttpRequest"
             xmlns:aedit="using:AvaloniaEdit"
             xmlns:views="using:Arbor.HttpClient.Desktop.Features.Variables"
             xmlns:loc="using:Arbor.HttpClient.Desktop.Localization"
             x:Class="Arbor.HttpClient.Desktop.Features.HttpRequest.RequestView"
             x:CompileBindings="False">

    <UserControl.Resources>
        <conv:MethodToColorConverter x:Key="MethodToColorConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10" Margin="8">

        <Grid.KeyBindings>
            <!-- Standard across Hoppscotch / Insomnia / Postman: Ctrl+Enter (or Cmd+Enter) sends the request -->
            <KeyBinding Gesture="Ctrl+Return" Command="{Binding App.SendRequestCommand}" />
            <KeyBinding Gesture="Cmd+Return" Command="{Binding App.SendRequestCommand}" />
        </Grid.KeyBindings>

        <!-- Row 0: Request type selector -->
        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
            <TextBlock Text="{x:Static loc:Strings.RequestTypeLabel}" VerticalAlignment="Center" Opacity="0.7" />
            <ComboBox Grid.Column="1" MinWidth="160"
                      ItemsSource="{Binding App.RequestEditor.RequestTypeOptions}"
                      SelectedItem="{Binding App.RequestEditor.SelectedRequestType, Mode=TwoWay}" />
        </Grid>

        <!-- Row 1: Request name + method + URL + Send -->
        <Grid Grid.Row="1" ColumnDefinitions="120,*,120" ColumnSpacing="8">
            <TextBox Grid.Column="0" PlaceholderText="{x:Static loc:Strings.RequestNamePlaceholder}"
                     Text="{Binding App.RequestEditor.RequestName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <!-- Unified composer: method + URL + Send are rendered as one seamless control
                 (Hoppscotch / Insomnia style). Wrap them in a single Border and strip
                 the inner corners so they visually butt up against each other. -->
            <Border Grid.Column="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1"
                    CornerRadius="3"
                    Background="{DynamicResource SurfaceBackgroundBrush}"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="Auto,Auto,*">
                    <!-- Method selector: hidden for protocols with a fixed method -->
                    <ComboBox Grid.Column="0" MinWidth="100"
                              BorderThickness="0"
                              CornerRadius="0"
                              Background="Transparent"
                              IsVisible="{Binding App.RequestEditor.IsHttpRequest}"
                              ItemsSource="{Binding App.RequestEditor.Methods}"
                              SelectedItem="{Binding App.RequestEditor.SelectedMethod, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="{Binding Converter={StaticResource MethodToColorConverter}}"
                                           FontWeight="SemiBold" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <!-- Fixed method badge for non-HTTP types -->
                    <Border Grid.Column="0"
                            IsVisible="{Binding App.RequestEditor.IsGraphQlRequest}"
                            Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static loc:Strings.RequestMethodPost}" FontWeight="SemiBold" Opacity="0.7" />
                    </Border>
                    <Border Grid.Column="0"
                            IsVisible="{Binding App.RequestEditor.IsWebSocketRequest}"
                            Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static loc:Strings.RequestMethodWebSocket}" FontWeight="SemiBold" Opacity="0.7" />
                    </Border>
                    <Border Grid.Column="0"
                            IsVisible="{Binding App.RequestEditor.IsSseRequest}"
                            Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static loc:Strings.RequestMethodGet}" FontWeight="SemiBold" Opacity="0.7" />
                    </Border>
                    <Border Grid.Column="0"
                            IsVisible="{Binding App.RequestEditor.IsGrpcRequest}"
                            Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static loc:Strings.RequestMethodGrpc}" FontWeight="SemiBold" Opacity="0.7" />
                    </Border>
                    <Rectangle Grid.Column="1" Width="1" VerticalAlignment="Stretch"
                               Fill="{DynamicResource PanelBorderBrush}" />
                    <Grid Grid.Column="2">
                        <aedit:TextEditor x:Name="RequestUrlEditor"
                                          ShowLineNumbers="False"
                                          WordWrap="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Padding="8,6,5,6"
                                          Background="Transparent" />
                        <!-- Placeholder overlay: AvaloniaEdit.TextEditor has no native PlaceholderText,
                             so we render one in parallel that hides as soon as the URL has any content. -->
                        <TextBlock Text="{x:Static loc:Strings.RequestUrlPlaceholder}"
                                   IsHitTestVisible="False"
                                   Opacity="0.5"
                                   Padding="10,6,5,6"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding App.RequestEditor.RequestUrl, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                    </Grid>
                </Grid>
            </Border>

            <Button x:Name="SendButton" Grid.Column="2" Content="{Binding App.PrimaryActionLabel}"
                    Classes="accent"
                    HorizontalContentAlignment="Center"
                    HorizontalAlignment="Stretch"
                    ToolTip.Tip="Send / Connect (Ctrl+Enter)"
                    Command="{Binding App.SendRequestCommand}" />
        </Grid>

        <!-- Row 2: Demo server banner — shown when the current request targets the local demo server
             but the demo server is not yet running. -->
        <Border Grid.Row="2"
                IsVisible="{Binding App.IsDemoServerBannerVisible}"
                Background="{DynamicResource PreviewPanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="10,7">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBlock VerticalAlignment="Center" TextWrapping="Wrap"
                           Text="{x:Static loc:Strings.RequestDemoBannerText}" />
                <Button Grid.Column="1" Content="{x:Static loc:Strings.RequestDemoBannerStartServer}"
                        AutomationProperties.Name="Start demo server"
                        Command="{Binding App.StartDemoServerCommand}" />
                <Button Grid.Column="2" Content="✕"
                        AutomationProperties.Name="Dismiss demo server banner"
                        Command="{Binding App.DismissDemoServerBannerCommand}" />
            </Grid>
        </Border>

        <!-- Row 3: HTTP-only options (follow redirects) -->
        <CheckBox Grid.Row="3"
                  IsVisible="{Binding App.RequestEditor.IsHttpRequest}"
                  Content="{x:Static loc:Strings.RequestFollowRedirects}"
                  IsChecked="{Binding App.RequestEditor.FollowRedirectsForRequest, Mode=TwoWay}" />

        <TextBlock Grid.Row="4" Text="{Binding App.ErrorMessage}" Foreground="{DynamicResource ErrorBrush}" />

        <!-- Row 5: Type-specific editor tabs -->
        <TabControl Grid.Row="5">

            <!-- ═══════════════════════════════ HTTP-only tabs ═══════════════════════════════ -->
            <TabItem Header="{x:Static loc:Strings.TabQuery}" IsVisible="{Binding App.RequestEditor.IsHttpRequest}">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,*" RowSpacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{x:Static loc:Strings.QueryParametersLabel}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="{x:Static loc:Strings.QueryParametersAddButton}"
                                Command="{Binding App.RequestEditor.AddQueryParameterCommand}" />
                    </Grid>

                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding App.RequestEditor.RequestQueryParameters}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RequestQueryParameterViewModel">
                                    <Grid ColumnDefinitions="Auto,*,*,*,Auto" ColumnSpacing="6" Margin="0,2,0,0">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center" />
                                        <views:VariableTextBox Grid.Column="1" PlaceholderText="{x:Static loc:Strings.QueryKeyPlaceholder}"
                                                 AppViewModel="{Binding $parent[UserControl].DataContext.App}"
                                                 Text="{Binding Key, Mode=TwoWay}" />
                                        <views:VariableTextBox Grid.Column="2" PlaceholderText="{x:Static loc:Strings.QueryValuePlaceholder}"
                                                 AppViewModel="{Binding $parent[UserControl].DataContext.App}"
                                                 Text="{Binding Value, Mode=TwoWay}" />
                                        <TextBox Grid.Column="3" PlaceholderText="{x:Static loc:Strings.QueryDescriptionPlaceholder}"
                                                 Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="4" Content="✕"
                                                Command="{Binding $parent[UserControl].DataContext.RemoveQueryParameterCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ─────────────────────── Body (HTTP) ─────────────────────────────────────────── -->
            <TabItem Header="{x:Static loc:Strings.TabBody}" IsVisible="{Binding App.RequestEditor.IsHttpRequest}">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,*">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{x:Static loc:Strings.RequestBodyLabel}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="{x:Static loc:Strings.RequestBodyOpenInEditor}"
                                Command="{Binding App.OpenRequestBodyInExternalEditorCommand}" />
                    </Grid>
                    <Border Grid.Row="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <aedit:TextEditor x:Name="RequestBodyEditor"
                                          ShowLineNumbers="True"
                                          WordWrap="True"
                                          MinHeight="150" />
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════ GraphQL tab ══════════════════════════════════ -->
            <TabItem Header="{x:Static loc:Strings.TabGraphQL}" IsVisible="{Binding App.RequestEditor.IsGraphQlRequest}">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="8">
                    <!-- Query editor -->
                    <TextBlock Text="{x:Static loc:Strings.GraphQlQueryLabel}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Grid.Row="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4" MinHeight="120">
                        <aedit:TextEditor x:Name="GraphQlQueryEditor"
                                          ShowLineNumbers="True"
                                          WordWrap="True" />
                    </Border>

                    <!-- Variables JSON editor -->
                    <TextBlock Grid.Row="2" Text="{x:Static loc:Strings.GraphQlVariablesLabel}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Grid.Row="3" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4" MinHeight="80">
                        <aedit:TextEditor x:Name="GraphQlVariablesEditor"
                                          ShowLineNumbers="True"
                                          WordWrap="True" />
                    </Border>

                    <!-- Operation name + introspection -->
                    <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <TextBlock Text="{x:Static loc:Strings.GraphQlOperationNameLabel}" VerticalAlignment="Center" Opacity="0.7" />
                        <TextBox Grid.Column="1" PlaceholderText="{x:Static loc:Strings.GraphQlOperationNamePlaceholder}"
                                 Text="{Binding App.GraphQlEditor.OperationName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2"
                                Content="{x:Static loc:Strings.GraphQlIntrospect}"
                                IsEnabled="{Binding !App.GraphQlEditor.IsIntrospecting}"
                                Command="{Binding App.GraphQlEditor.IntrospectSchemaCommand}"
                                CommandParameter="{Binding App.RequestEditor.RequestUrl}"
                                ToolTip.Tip="Fetch the GraphQL schema from the endpoint" />
                    </Grid>

                    <!-- Introspection result / error -->
                    <StackPanel Grid.Row="5" Spacing="4">
                        <TextBlock Text="{Binding App.GraphQlEditor.IntrospectionError}"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   IsVisible="{Binding App.GraphQlEditor.IntrospectionError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   TextWrapping="Wrap" />
                        <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4"
                                IsVisible="{Binding App.GraphQlEditor.SchemaJson, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <aedit:TextEditor x:Name="GraphQlSchemaEditor"
                                              IsReadOnly="True"
                                              ShowLineNumbers="False"
                                              WordWrap="True"
                                              MaxHeight="200" />
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════ WebSocket tab ════════════════════════════════ -->
            <TabItem Header="{x:Static loc:Strings.TabWebSocket}" IsVisible="{Binding App.RequestEditor.IsWebSocketRequest}">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                    <!-- Connection status -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock VerticalAlignment="Center"
                                   Text="{x:Static loc:Strings.WsConnected}"
                                   Foreground="{DynamicResource StatusSuccessBrush}"
                                   IsVisible="{Binding App.WebSocketSession.IsConnected}" />
                        <TextBlock VerticalAlignment="Center"
                                   Text="{x:Static loc:Strings.WsDisconnected}"
                                   Opacity="0.6"
                                   IsVisible="{Binding !App.WebSocketSession.IsConnected}" />
                    </StackPanel>

                    <!-- Error -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding App.WebSocketSession.ConnectionError}"
                               Foreground="{DynamicResource ErrorBrush}"
                               IsVisible="{Binding App.WebSocketSession.ConnectionError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               TextWrapping="Wrap" />

                    <!-- Message send area -->
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8"
                          IsEnabled="{Binding App.WebSocketSession.IsConnected}">
                        <TextBox PlaceholderText="{x:Static loc:Strings.WsMessagePlaceholder}"
                                 Text="{Binding App.WebSocketSession.MessageToSend, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False">
                            <TextBox.KeyBindings>
                                <KeyBinding Gesture="Return" Command="{Binding App.WebSocketSession.SendMessageCommand}" />
                            </TextBox.KeyBindings>
                        </TextBox>
                        <Button Grid.Column="1" Content="{x:Static loc:Strings.WsSend}"
                                Command="{Binding App.WebSocketSession.SendMessageCommand}" />
                    </Grid>

                    <!-- Message log -->
                    <Grid Grid.Row="3" RowDefinitions="Auto,*">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{x:Static loc:Strings.WsMessages}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="{x:Static loc:Strings.WsClear}"
                                    Command="{Binding App.WebSocketSession.ClearMessagesCommand}" />
                        </Grid>
                        <ScrollViewer Grid.Row="1">
                            <ItemsControl ItemsSource="{Binding App.WebSocketSession.Messages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,2,0,0" Padding="6,4" CornerRadius="4"
                                                Background="{DynamicResource PreviewPanelBackgroundBrush}">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <TextBlock Text="→" FontWeight="SemiBold" Margin="0,0,6,0"
                                                           Opacity="0.6"
                                                           IsVisible="{Binding Direction, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Content}"
                                                           TextWrapping="Wrap"
                                                           FontFamily="{Binding $parent[UserControl].DataContext.App.UiFontFamily}"
                                                           FontSize="{Binding $parent[UserControl].DataContext.App.UiFontSize}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════ SSE tab ══════════════════════════════════════ -->
            <TabItem Header="{x:Static loc:Strings.TabSse}" IsVisible="{Binding App.RequestEditor.IsSseRequest}">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                    <!-- Connection status -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding App.SseSession.StatusMessage}"
                                   Opacity="0.8" />
                    </StackPanel>

                    <!-- Error -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding App.SseSession.ConnectionError}"
                               Foreground="{DynamicResource ErrorBrush}"
                               IsVisible="{Binding App.SseSession.ConnectionError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               TextWrapping="Wrap" />

                    <!-- Events log -->
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                        <TextBlock Text="{x:Static loc:Strings.SseEvents}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="{x:Static loc:Strings.SseClear}"
                                Command="{Binding App.SseSession.ClearEventsCommand}" />
                    </Grid>

                    <ScrollViewer Grid.Row="3">
                        <ItemsControl ItemsSource="{Binding App.SseSession.Events}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,2,0,0" Padding="6,4" CornerRadius="4"
                                            Background="{DynamicResource PreviewPanelBackgroundBrush}">
                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Timestamp}"
                                                           FontSize="11" Opacity="0.6" />
                                                <TextBlock Text="{Binding EventType}"
                                                           FontWeight="SemiBold"
                                                           IsVisible="{Binding EventType, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                                <TextBlock Text="{Binding Id}"
                                                           Opacity="0.6"
                                                           IsVisible="{Binding Id, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Text="{Binding Data}"
                                                       TextWrapping="Wrap"
                                                       FontFamily="{Binding $parent[UserControl].DataContext.App.UiFontFamily}"
                                                       FontSize="{Binding $parent[UserControl].DataContext.App.UiFontSize}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════ gRPC tab ══════════════════════════════════════ -->
            <TabItem Header="{x:Static loc:Strings.TabGrpc}" IsVisible="{Binding App.RequestEditor.IsGrpcRequest}">
                <StackPanel Margin="0,16,0,0" Spacing="12">
                    <TextBlock Text="{x:Static loc:Strings.GrpcTitle}" FontWeight="SemiBold" FontSize="14" />
                    <Border Background="{DynamicResource PreviewPanelBackgroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{x:Static loc:Strings.GrpcWarningTitle}" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Static loc:Strings.GrpcDescription}" TextWrapping="Wrap" Opacity="0.8" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- ═══════════════════════════════ Shared: Headers tab ════════════════════════════ -->
            <TabItem Header="{x:Static loc:Strings.TabHeaders}">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,*" RowSpacing="6">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{x:Static loc:Strings.HeadersLabel}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="{x:Static loc:Strings.HeadersAddButton}"
                                Command="{Binding App.RequestEditor.AddHeaderCommand}" />
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="110,*,*" ColumnSpacing="6"
                          IsVisible="{Binding App.RequestEditor.IsHttpRequest}">
                        <TextBlock Text="{x:Static loc:Strings.HeadersContentTypeLabel}" VerticalAlignment="Center" Opacity="0.7" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding App.RequestEditor.ContentTypeOptions}"
                                  SelectedItem="{Binding App.RequestEditor.SelectedContentTypeOption, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch" />
                        <TextBox Grid.Column="2"
                                 PlaceholderText="{x:Static loc:Strings.HeadersContentTypePlaceholder}"
                                 Text="{Binding App.RequestEditor.CustomContentType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsVisible="{Binding App.RequestEditor.IsCustomContentType}" />
                    </Grid>

                    <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding App.RequestEditor.RequestHeaders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RequestHeaderViewModel">
                                    <Grid ColumnDefinitions="Auto,*,*,*,Auto" ColumnSpacing="6" Margin="0,2,0,0">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center" />
                                        <views:VariableTextBox Grid.Column="1" PlaceholderText="{x:Static loc:Strings.HeadersKeyPlaceholder}"
                                                 AppViewModel="{Binding $parent[UserControl].DataContext.App}"
                                                 Text="{Binding Name, Mode=TwoWay}" />
                                        <views:VariableTextBox Grid.Column="2" PlaceholderText="{x:Static loc:Strings.HeadersValuePlaceholder}"
                                                 AppViewModel="{Binding $parent[UserControl].DataContext.App}"
                                                 Text="{Binding Value, Mode=TwoWay}" />
                                        <TextBox Grid.Column="3" PlaceholderText="{x:Static loc:Strings.HeadersDescriptionPlaceholder}"
                                                 Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="4" Content="✕"
                                                Command="{Binding $parent[UserControl].DataContext.RemoveHeaderCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════ Auth tab (HTTP / GraphQL) ══════════════════════ -->
            <TabItem Header="{x:Static loc:Strings.TabAuth}">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="8">
                    <Grid ColumnDefinitions="130,*" ColumnSpacing="8">
                        <TextBlock Text="{x:Static loc:Strings.AuthTypeLabel}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding App.RequestEditor.AuthModeOptions}"
                                  SelectedItem="{Binding App.RequestEditor.SelectedAuthModeOption, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Row="1" ColumnDefinitions="130,*" ColumnSpacing="8"
                          IsVisible="{Binding App.RequestEditor.IsBearerAuthMode}">
                        <TextBlock Text="{x:Static loc:Strings.AuthTokenLabel}" VerticalAlignment="Center" />
                        <views:VariableTextBox Grid.Column="1" PlaceholderText="{x:Static loc:Strings.AuthBearerTokenPlaceholder}"
                                               AppViewModel="{Binding App}"
                                               Text="{Binding App.RequestEditor.AuthBearerToken, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="130,*" ColumnSpacing="8"
                          IsVisible="{Binding App.RequestEditor.IsBasicAuthMode}">
                        <TextBlock Text="{x:Static loc:Strings.AuthUsernameLabel}" VerticalAlignment="Center" />
                        <views:VariableTextBox Grid.Column="1" PlaceholderText="{x:Static loc:Strings.AuthUsernamePlaceholder}"
                                               AppViewModel="{Binding App}"
                                               Text="{Binding App.RequestEditor.AuthBasicUsername, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Row="3" ColumnDefinitions="130,*" ColumnSpacing="8"
                          IsVisible="{Binding App.RequestEditor.IsBasicAuthMode}">
                        <TextBlock Text="{x:Static loc:Strings.AuthPasswordLabel}" VerticalAlignment="Center" />
                        <views:VariableTextBox Grid.Column="1" PlaceholderText="{x:Static loc:Strings.AuthPasswordPlaceholder}"
                                               AppViewModel="{Binding App}"
                                               Text="{Binding App.RequestEditor.AuthBasicPassword, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Row="4" ColumnDefinitions="130,*" ColumnSpacing="8"
                          IsVisible="{Binding App.RequestEditor.IsApiKeyAuthMode}">
                        <TextBlock Text="{x:Static loc:Strings.AuthApiKeyLabel}" VerticalAlignment="Center" />
                        <views:VariableTextBox Grid.Column="1" PlaceholderText="{x:Static loc:Strings.AuthApiKeyPlaceholder}"
                                               AppViewModel="{Binding App}"
                                               Text="{Binding App.RequestEditor.AuthApiKey, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Row="5" ColumnDefinitions="130,*" ColumnSpacing="8"
                          IsVisible="{Binding App.RequestEditor.IsOAuth2ClientCredentialsAuthMode}">
                        <TextBlock Text="{x:Static loc:Strings.AuthAccessTokenLabel}" VerticalAlignment="Center" />
                        <views:VariableTextBox Grid.Column="1" PlaceholderText="{x:Static loc:Strings.AuthOAuth2Placeholder}"
                                               AppViewModel="{Binding App}"
                                               Text="{Binding App.RequestEditor.AuthOAuth2AccessToken, Mode=TwoWay}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════ Preview tab (HTTP only) ════════════════════════ -->
            <TabItem Header="{x:Static loc:Strings.TabPreview}" IsVisible="{Binding App.RequestEditor.IsHttpRequest}">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,*">
                    <TextBlock Text="{x:Static loc:Strings.PreviewLabel}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Border Grid.Row="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <aedit:TextEditor x:Name="RequestPreviewEditor"
                                          IsReadOnly="True"
                                          ShowLineNumbers="True"
                                          WordWrap="True"
                                          MinHeight="150" />
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════ Notes tab (all types) ═════════════════════════ -->
            <TabItem Header="{x:Static loc:Strings.TabNotes}">
                <Grid Margin="0,8,0,0" RowDefinitions="Auto,*" RowSpacing="6">
                    <TextBlock Text="{x:Static loc:Strings.NotesLabel}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1"
                             PlaceholderText="{x:Static loc:Strings.NotesFreeformPlaceholder}"
                             Text="{Binding App.RequestEditor.RequestNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="150" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

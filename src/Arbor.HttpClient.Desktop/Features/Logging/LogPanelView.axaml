<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Arbor.HttpClient.Desktop.Features.Logging"
             xmlns:logging="using:Arbor.HttpClient.Desktop.Features.Logging"
             x:Class="Arbor.HttpClient.Desktop.Features.Logging.LogPanelView"
             x:CompileBindings="False">
    <Grid RowDefinitions="Auto,*" Margin="12" RowSpacing="8">
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Live Log" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            <CheckBox Grid.Column="1" Content="Auto-scroll"
                      IsChecked="{Binding App.LogWindowViewModel.AutoScroll, Mode=TwoWay}"
                      VerticalAlignment="Center" />
        </Grid>

        <TabControl Grid.Row="1">
            <TabItem Header="Scheduled">
                <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                    <ListBox x:Name="ScheduledLogList"
                             ItemsSource="{Binding App.LogWindowViewModel.Entries}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource SurfaceBackgroundBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="logging:LogEntry">
                                <Grid ColumnDefinitions="160,80,*" ColumnSpacing="8">
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss.fff}'}"
                                               FontFamily="{DynamicResource AppFontFamily}"
                                               FontSize="11"
                                               Opacity="0.7"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Level}"
                                               FontFamily="{DynamicResource AppFontFamily}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Message}"
                                               FontFamily="{DynamicResource AppFontFamily}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </TabItem>
            <TabItem Header="HTTP Diagnostics">
                <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                    <ListBox x:Name="DiagnosticsLogList"
                             ItemsSource="{Binding App.LogWindowViewModel.HttpDiagnosticsEntries}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource SurfaceBackgroundBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="logging:LogEntry">
                                <Grid ColumnDefinitions="160,80,*" ColumnSpacing="8">
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss.fff}'}"
                                               FontFamily="{DynamicResource AppFontFamily}"
                                               FontSize="11"
                                               Opacity="0.7"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Level}"
                                               FontFamily="{DynamicResource AppFontFamily}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Message}"
                                               FontFamily="{DynamicResource AppFontFamily}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </TabItem>
            <TabItem Header="HTTP Requests">
                <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                    <ListBox x:Name="RequestLogList"
                             ItemsSource="{Binding App.LogWindowViewModel.HttpRequestEntries}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource SurfaceBackgroundBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="logging:LogEntry">
                                <Grid ColumnDefinitions="160,80,*" ColumnSpacing="8">
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss.fff}'}"
                                               FontFamily="{DynamicResource AppFontFamily}"
                                               FontSize="11"
                                               Opacity="0.7"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Level}"
                                               FontFamily="{DynamicResource AppFontFamily}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Message}"
                                               FontFamily="{DynamicResource AppFontFamily}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </TabItem>
            <TabItem Header="Debug">
                <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                    <ListBox x:Name="DebugLogList"
                             ItemsSource="{Binding App.LogWindowViewModel.DebugEntries}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource SurfaceBackgroundBrush}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="logging:LogEntry">
                                <Grid ColumnDefinitions="160,80,*" ColumnSpacing="8">
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss.fff}'}"
                                               FontFamily="{DynamicResource AppFontFamily}"
                                               FontSize="11"
                                               Opacity="0.7"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Level}"
                                               FontFamily="{DynamicResource AppFontFamily}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Message}"
                                               FontFamily="{DynamicResource AppFontFamily}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

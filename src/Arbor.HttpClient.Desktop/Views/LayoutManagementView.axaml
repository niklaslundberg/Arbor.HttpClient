<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Arbor.HttpClient.Desktop.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="400"
             x:Class="Arbor.HttpClient.Desktop.Views.LayoutManagementView"
             x:DataType="vm:LayoutManagementViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="12" Spacing="12">

            <TextBlock Text="Window Layout"
                       FontSize="16"
                       FontWeight="SemiBold" />

            <StackPanel Spacing="6">
                <TextBlock Text="Saved layouts:" />
                <ComboBox MinWidth="180"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{Binding App.SavedLayoutNames}"
                          SelectedItem="{Binding App.SelectedLayoutName, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <Button Content="Save As New"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SaveLayoutAsNewCommand}" />
                <Button Content="Save to Selected"
                        HorizontalAlignment="Stretch"
                        Command="{Binding SaveLayoutToExistingCommand}"
                        CommandParameter="{Binding App.SelectedLayoutName}" />
                <Button Content="Remove Selected"
                        HorizontalAlignment="Stretch"
                        Command="{Binding RemoveLayoutCommand}"
                        CommandParameter="{Binding App.SelectedLayoutName}" />
                <Button Content="Restore Default"
                        HorizontalAlignment="Stretch"
                        Command="{Binding RestoreDefaultLayoutCommand}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>

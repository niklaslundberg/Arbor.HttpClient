<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Arbor.HttpClient.Desktop.Features.Main"
        xmlns:conv="using:Arbor.HttpClient.Desktop.Features.HttpRequest"
        xmlns:envconv="using:Arbor.HttpClient.Desktop.Features.Environments"
        xmlns:shared="using:Arbor.HttpClient.Desktop.Shared"
        xmlns:environments="using:Arbor.HttpClient.Core.Environments"
        xmlns:dock="using:Dock.Avalonia.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="using:Arbor.HttpClient.Desktop.Localization"
        mc:Ignorable="d" d:DesignWidth="1300" d:DesignHeight="820"
        x:Class="Arbor.HttpClient.Desktop.Features.Main.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{x:Static loc:Strings.MainWindowTitle}"
        Width="1300"
        Height="820"
        FontFamily="{Binding UiFontFamily}"
        FontSize="{Binding UiFontSize}">

    <Window.Resources>
        <conv:MethodToColorConverter x:Key="MethodToColorConverter" />
        <envconv:HexColorToBrushConverter x:Key="HexColorToBrushConverter" />
        <shared:NotNullConverter x:Key="NotNullConverter" />
    </Window.Resources>

    <Window.Styles>
        <!-- Shared style for every activity-bar icon button -->
        <Style Selector="Button.ActivityBarButton">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Styles>

    <DockPanel Margin="0">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="{x:Static loc:Strings.MenuFile}">
                <MenuItem Header="{x:Static loc:Strings.MenuImportOpenApi}" Command="{Binding ImportCollectionCommand}" />
                <Separator />
                <MenuItem Header="{x:Static loc:Strings.MenuExit}" Command="{Binding ExitApplicationCommand}" />
            </MenuItem>
            <MenuItem Header="{x:Static loc:Strings.MenuView}">
                <MenuItem Header="{x:Static loc:Strings.MenuHistory}" Command="{Binding ShowHistoryTabCommand}" />
                <MenuItem Header="{x:Static loc:Strings.MenuCollections}" Command="{Binding ShowCollectionsTabCommand}" />
                <MenuItem Header="{x:Static loc:Strings.MenuScheduledJobs}" Command="{Binding ShowScheduledJobsTabCommand}" />
                <Separator />
                <MenuItem Header="{x:Static loc:Strings.MenuOptions}" Command="{Binding OpenOptionsCommand}" />
                <MenuItem Header="{x:Static loc:Strings.MenuEnvironments}" Command="{Binding OpenEnvironmentsCommand}" />
                <MenuItem Header="{x:Static loc:Strings.MenuCookies}" Command="{Binding OpenCookieJarCommand}" />
                <MenuItem Header="{x:Static loc:Strings.MenuLogs}" Command="{Binding OpenLogWindowCommand}" />
                <MenuItem Header="{x:Static loc:Strings.MenuLayout}" Command="{Binding OpenLayoutPanelCommand}" />
            </MenuItem>
            <MenuItem Header="{x:Static loc:Strings.MenuHelp}">
                <MenuItem Header="{x:Static loc:Strings.MenuAbout}" Command="{Binding OpenAboutCommand}" />
                <MenuItem Header="{x:Static loc:Strings.MenuDiagnostics}" Command="{Binding OpenDiagnosticsCommand}" />
            </MenuItem>
        </Menu>

        <!-- Top toolbar: title and environment selector -->
        <Border DockPanel.Dock="Top" Padding="16,10" BorderBrush="{DynamicResource TopToolbarBorderBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{x:Static loc:Strings.AppTitle}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />

                <!-- Environment selector with color circle indicator -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static loc:Strings.ToolbarEnvLabel}" VerticalAlignment="Center" Opacity="0.7" />
                    <ComboBox MinWidth="160"
                              ItemsSource="{Binding Environments}"
                              SelectedItem="{Binding ActiveEnvironment, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="environments:RequestEnvironment">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <!-- Color dot: shows each environment's accent color in the dropdown
                                         so users can see colors before making a selection. -->
                                    <Ellipse Width="10" Height="10"
                                             VerticalAlignment="Center"
                                             Fill="{Binding AccentColor, Converter={StaticResource HexColorToBrushConverter}}"
                                             IsVisible="{Binding AccentColor, Converter={StaticResource NotNullConverter}}" />
                                    <TextBlock Text="{Binding Name}" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Environment warning banner (Pattern B): shown when active environment has ShowWarningBanner=true -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding ActiveEnvironmentShowWarningBanner}"
                Background="{Binding ActiveEnvironmentAccentColor, Converter={StaticResource HexColorToBrushConverter}}"
                Padding="16,4"
                MinHeight="28">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{x:Static loc:Strings.EnvironmentsWarningBannerText}"
                           Foreground="{DynamicResource AccentOnColorBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding ActiveEnvironment.Name, FallbackValue=''}"
                           Foreground="{DynamicResource AccentOnColorBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Draft restore banner: shown after a crash or unexpected exit -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasDraftToRestore}"
                Background="{DynamicResource SecondaryPanelBackgroundBrush}"
                Padding="16,8"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="{Binding DraftRestoreMessage}"
                           VerticalAlignment="Center" />
                <Button Content="{x:Static loc:Strings.DraftRestore}"
                        Command="{Binding RestoreDraftCommand}" />
                <Button Content="{x:Static loc:Strings.DraftDiscard}"
                        Command="{Binding DiscardDraftCommand}" />
            </StackPanel>
        </Border>

        <!-- Main content area: VSCode-style activity bar + dockable panels -->
        <Grid ColumnDefinitions="Auto,*">

            <!-- VSCode-style Activity Bar -->
            <Border Grid.Column="0"
                    Width="48"
                    Background="{DynamicResource OptionsNavBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="*,Auto">

                    <!-- Main navigation buttons -->
                    <StackPanel Grid.Row="0" Orientation="Vertical" Spacing="2" Margin="4,8,4,0">
                        <Button Classes="ActivityBarButton"
                                Command="{Binding ShowCollectionsTabCommand}"
                                ToolTip.Tip="{x:Static loc:Strings.ActivityBarCollections}"
                                AutomationProperties.Name="{x:Static loc:Strings.ActivityBarCollections}">
                            <TextBlock Text="📁" FontSize="18" HorizontalAlignment="Center" IsHitTestVisible="False" />
                        </Button>
                        <!-- Environments button with optional color badge dot (Pattern D) -->
                        <Button Classes="ActivityBarButton"
                                Command="{Binding OpenEnvironmentsCommand}"
                                ToolTip.Tip="{x:Static loc:Strings.ActivityBarEnvironments}"
                                AutomationProperties.Name="{x:Static loc:Strings.ActivityBarEnvironments}">
                            <Panel>
                                <TextBlock Text="🌐" FontSize="18" HorizontalAlignment="Center" IsHitTestVisible="False" />
                                <!-- Badge dot: visible when an accent color is set -->
                                <Ellipse Width="10" Height="10"
                                         HorizontalAlignment="Right" VerticalAlignment="Top"
                                         Margin="0,2,2,0"
                                         Fill="{Binding ActiveEnvironmentAccentColor, Converter={StaticResource HexColorToBrushConverter}}"
                                         IsVisible="{Binding ActiveEnvironmentHasColor}"
                                         IsHitTestVisible="False" />
                            </Panel>
                        </Button>
                        <Button Classes="ActivityBarButton"
                                Command="{Binding OpenOptionsCommand}"
                                ToolTip.Tip="{x:Static loc:Strings.ActivityBarOptions}"
                                AutomationProperties.Name="{x:Static loc:Strings.ActivityBarOptions}">
                            <TextBlock Text="⚙" FontSize="18" HorizontalAlignment="Center" IsHitTestVisible="False" />
                        </Button>
                        <Button Classes="ActivityBarButton"
                                Command="{Binding OpenCookieJarCommand}"
                                ToolTip.Tip="{x:Static loc:Strings.ActivityBarCookies}"
                                AutomationProperties.Name="{x:Static loc:Strings.ActivityBarCookies}">
                            <TextBlock Text="🍪" FontSize="18" HorizontalAlignment="Center" IsHitTestVisible="False" />
                        </Button>
                        <Button Classes="ActivityBarButton"
                                Command="{Binding OpenLogWindowCommand}"
                                ToolTip.Tip="{x:Static loc:Strings.ActivityBarLogs}"
                                AutomationProperties.Name="{x:Static loc:Strings.ActivityBarLogs}">
                            <TextBlock Text="📋" FontSize="18" HorizontalAlignment="Center" IsHitTestVisible="False" />
                        </Button>
                        <Button Classes="ActivityBarButton"
                                Command="{Binding ImportCollectionCommand}"
                                ToolTip.Tip="{x:Static loc:Strings.ActivityBarImportOpenApi}"
                                AutomationProperties.Name="{x:Static loc:Strings.ActivityBarImportOpenApi}">
                            <TextBlock Text="📥" FontSize="18" HorizontalAlignment="Center" IsHitTestVisible="False" />
                        </Button>
                    </StackPanel>

                    <!-- Bottom auxiliary buttons -->
                    <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="2" Margin="4,0,4,8">
                        <Button Classes="ActivityBarButton"
                                Command="{Binding OpenAboutCommand}"
                                ToolTip.Tip="{x:Static loc:Strings.ActivityBarAbout}"
                                AutomationProperties.Name="{x:Static loc:Strings.ActivityBarAbout}">
                            <TextBlock Text="ℹ" FontSize="18" HorizontalAlignment="Center" IsHitTestVisible="False" />
                        </Button>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- Dockable main content area -->
            <dock:DockControl Grid.Column="1" Layout="{Binding Layout}"
                              Factory="{Binding Factory}" />
        </Grid>
    </DockPanel>
</Window>


<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Arbor.HttpClient.Desktop.Features.Collections"
             xmlns:conv="using:Arbor.HttpClient.Desktop.Shared"
             xmlns:convHttp="using:Arbor.HttpClient.Desktop.Features.HttpRequest"
             xmlns:convColl="using:Arbor.HttpClient.Desktop.Features.Collections"
             xmlns:scheduledVm="using:Arbor.HttpClient.Desktop.Features.ScheduledJobs"
             xmlns:collections="using:Arbor.HttpClient.Core.Collections"
             xmlns:httpRequest="using:Arbor.HttpClient.Core.HttpRequest"
             xmlns:loc="using:Arbor.HttpClient.Desktop.Localization"
             x:Class="Arbor.HttpClient.Desktop.Features.Collections.LeftPanelView"
             x:CompileBindings="False">

    <UserControl.Resources>
        <convHttp:MethodToColorConverter x:Key="MethodToColorConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Tab-styled buttons for the History / Collections / Scheduled selector,
             matching the look of TabControl TabItems used elsewhere (flat, with
             an accent underline on the active tab). -->
        <Style Selector="Button.tab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="Button.tab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.tab.active">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <!-- Small compact action buttons used within the collection toolbar -->
        <Style Selector="Button.compact">
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="8" Background="{DynamicResource PanelBackgroundBrush}">
        <!-- Tab bar -->
        <StackPanel Orientation="Horizontal" Spacing="0">
            <Button Classes="tab" Content="{x:Static loc:Strings.LeftPanelHistory}"
                    Command="{Binding App.ShowHistoryTabCommand}"
                    Classes.active="{Binding App.LeftPanelTab, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=History}" />
            <Button Classes="tab" Content="{x:Static loc:Strings.LeftPanelCollections}"
                    Command="{Binding App.ShowCollectionsTabCommand}"
                    Classes.active="{Binding App.LeftPanelTab, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Collections}" />
            <Button Classes="tab" Content="{x:Static loc:Strings.LeftPanelScheduled}"
                    Command="{Binding App.ShowScheduledJobsTabCommand}"
                    Classes.active="{Binding App.LeftPanelTab, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=ScheduledJobs}" />
        </StackPanel>

        <!-- History tab -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" Padding="12" CornerRadius="8"
                IsVisible="{Binding App.LeftPanelTab, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=History}">
            <Grid RowDefinitions="Auto,*">
                <TextBox PlaceholderText="{x:Static loc:Strings.LeftPanelSearchHistory}"
                         Text="{Binding App.HistorySearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <ListBox Grid.Row="1" ItemsSource="{Binding App.History}" Margin="0,6,0,0"
                         Background="{DynamicResource PanelBackgroundBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="httpRequest:SavedRequest">
                            <StackPanel Margin="0,4">
                                <StackPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{x:Static loc:Strings.LeftPanelCopyAsCurl}"
                                                  Command="{Binding $parent[UserControl].DataContext.App.CopyHistoryItemAsCurlCommand}"
                                                  CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <TextBlock Text="{Binding Method}"
                                               Foreground="{Binding Method, Converter={StaticResource MethodToColorConverter}}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CreatedAtLocalDisplay}"
                                               HorizontalAlignment="Right"
                                               FontSize="10"
                                               Opacity="0.65" />
                                </Grid>
                                <TextBlock Text="{Binding Url}" TextWrapping="Wrap" FontSize="11" Opacity="0.7" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Collections tab -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" Padding="12" CornerRadius="8"
                IsVisible="{Binding App.LeftPanelTab, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Collections}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*">

                <!-- Row 0: Collection selector + New button -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                    <ComboBox ItemsSource="{Binding App.Collections}"
                              SelectedItem="{Binding App.SelectedCollection, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="collections:Collection">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="1" Classes="compact"
                            Content="{x:Static loc:Strings.LeftPanelNewCollection}"
                            AutomationProperties.Name="Create new collection"
                            ToolTip.Tip="Create a new empty collection"
                            Command="{Binding App.ShowNewCollectionFormCommand}" />
                </Grid>

                <!-- Row 1: Inline new-collection form -->
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4" Margin="0,4,0,0"
                      IsVisible="{Binding App.IsNewCollectionFormVisible}">
                    <TextBox PlaceholderText="{x:Static loc:Strings.LeftPanelCollectionNamePlaceholder}"
                             Text="{Binding App.NewCollectionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1" Classes="compact" Content="✓"
                            AutomationProperties.Name="Confirm new collection"
                            Command="{Binding App.CreateCollectionCommand}" />
                    <Button Grid.Column="2" Classes="compact" Content="✕"
                            AutomationProperties.Name="Cancel new collection"
                            Command="{Binding App.CancelNewCollectionCommand}" />
                </Grid>

                <!-- Row 2: Per-collection action buttons (visible when a collection is selected) -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0"
                            IsVisible="{Binding App.SelectedCollection, Converter={x:Static conv:NotNullConverter.Instance}}">
                    <Button Classes="compact"
                            Content="{x:Static loc:Strings.LeftPanelAddRequest}"
                            AutomationProperties.Name="Add current request to collection"
                            ToolTip.Tip="Add the current request to this collection"
                            Command="{Binding App.AddRequestToCollectionCommand}" />
                    <Button Classes="compact"
                            Content="{x:Static loc:Strings.LeftPanelImportOpenApi}"
                            AutomationProperties.Name="Import OpenAPI specification"
                            Command="{Binding App.ImportCollectionCommand}" />
                    <Button Classes="compact"
                            Content="{x:Static loc:Strings.LeftPanelRenameCollection}"
                            AutomationProperties.Name="Rename collection"
                            ToolTip.Tip="Rename this collection"
                            Command="{Binding App.ShowRenameCollectionFormCommand}" />
                    <Button Classes="compact"
                            Content="{x:Static loc:Strings.LeftPanelDeleteCollection}"
                            AutomationProperties.Name="Delete collection"
                            Command="{Binding App.DeleteCollectionCommand}"
                            CommandParameter="{Binding App.SelectedCollection}" />
                </StackPanel>

                <!-- Row 3: Inline rename-collection form -->
                <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4" Margin="0,4,0,0"
                      IsVisible="{Binding App.IsRenameCollectionFormVisible}">
                    <TextBox PlaceholderText="{x:Static loc:Strings.LeftPanelRenameCollectionNamePlaceholder}"
                             Text="{Binding App.RenameCollectionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1" Classes="compact" Content="✓"
                            AutomationProperties.Name="Confirm rename collection"
                            Command="{Binding App.ConfirmRenameCollectionCommand}" />
                    <Button Grid.Column="2" Classes="compact" Content="✕"
                            AutomationProperties.Name="Cancel rename collection"
                            Command="{Binding App.CancelRenameCollectionCommand}" />
                </Grid>

                <!-- Row 4: Search box -->
                <TextBox Grid.Row="4" Margin="0,6,0,0"
                         PlaceholderText="{x:Static loc:Strings.LeftPanelSearchRequests}"
                         Text="{Binding App.CollectionSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Row 5: Sort + view-mode toolbar -->
                <Grid Grid.Row="5" RowDefinitions="Auto,Auto" Margin="0,4,0,0">
                    <!-- Sort row -->
                    <StackPanel Orientation="Horizontal" Spacing="0">
                        <TextBlock Text="{x:Static loc:Strings.LeftPanelSortLabel}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,4,0" FontSize="11" />
                        <Button Classes="tab" Content="{x:Static loc:Strings.LeftPanelSortDefault}" FontSize="11" Padding="6,4"
                                Command="{Binding App.SetCollectionSortByCommand}" CommandParameter="Default"
                                Classes.active="{Binding App.CollectionSortBy, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Default}" />
                        <Button Classes="tab" Content="{x:Static loc:Strings.LeftPanelSortName}" FontSize="11" Padding="6,4"
                                Command="{Binding App.SetCollectionSortByCommand}" CommandParameter="Name"
                                Classes.active="{Binding App.CollectionSortBy, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Name}" />
                        <Button Classes="tab" Content="{x:Static loc:Strings.LeftPanelSortMethod}" FontSize="11" Padding="6,4"
                                Command="{Binding App.SetCollectionSortByCommand}" CommandParameter="Method"
                                Classes.active="{Binding App.CollectionSortBy, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Method}" />
                        <Button Classes="tab" Content="{x:Static loc:Strings.LeftPanelSortPath}" FontSize="11" Padding="6,4"
                                Command="{Binding App.SetCollectionSortByCommand}" CommandParameter="Path"
                                Classes.active="{Binding App.CollectionSortBy, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=Path}" />
                    </StackPanel>
                    <!-- Display mode row -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="0" Margin="0,2,0,0">
                        <TextBlock Text="{x:Static loc:Strings.LeftPanelShowLabel}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,4,0" FontSize="11" />
                        <Button Classes="tab" Content="{x:Static loc:Strings.LeftPanelShowNameAndPath}" FontSize="11" Padding="6,4"
                                Command="{Binding App.SetCollectionDisplayModeCommand}" CommandParameter="NameAndPath"
                                Classes.active="{Binding App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=NameAndPath}" />
                        <Button Classes="tab" Content="{x:Static loc:Strings.LeftPanelShowName}" FontSize="11" Padding="6,4"
                                Command="{Binding App.SetCollectionDisplayModeCommand}" CommandParameter="NameOnly"
                                Classes.active="{Binding App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=NameOnly}" />
                        <Button Classes="tab" Content="{x:Static loc:Strings.LeftPanelShowPath}" FontSize="11" Padding="6,4"
                                Command="{Binding App.SetCollectionDisplayModeCommand}" CommandParameter="PathOnly"
                                Classes.active="{Binding App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=PathOnly}" />
                        <Button Classes="tab" Content="{x:Static loc:Strings.LeftPanelShowUrl}" FontSize="11" Padding="6,4"
                                Command="{Binding App.SetCollectionDisplayModeCommand}" CommandParameter="FullUrl"
                                Classes.active="{Binding App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=FullUrl}" />
                        <Button Classes="tab" Content="{x:Static loc:Strings.LeftPanelTreeView}" FontSize="11" Padding="6,4"
                                AutomationProperties.Name="Toggle tree view"
                                Command="{Binding App.ToggleCollectionTreeViewCommand}"
                                Classes.active="{Binding App.IsCollectionTreeView}" />
                    </StackPanel>
                </Grid>

                <!-- Row 6: Flat list view (default) -->
                <ScrollViewer Grid.Row="6" Margin="0,6,0,0"
                              IsVisible="{Binding !App.IsCollectionTreeView}">
                    <ItemsControl ItemsSource="{Binding App.FilteredCollectionItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CollectionItemViewModel">
                                <Button Background="Transparent"
                                        BorderBrush="Transparent"
                                        Padding="4,3"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Command="{Binding $parent[UserControl].DataContext.App.LoadCollectionRequestCommand}"
                                        CommandParameter="{Binding}">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6" Margin="0,3">
                                        <TextBlock Text="{Binding Method}"
                                                   Foreground="{Binding Method, Converter={StaticResource MethodToColorConverter}}"
                                                   FontWeight="SemiBold" MinWidth="50" />
                                        <StackPanel Grid.Column="1">
                                            <!-- Name — shown in NameAndPath and NameOnly -->
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       IsVisible="{Binding $parent[UserControl].DataContext.App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=NameAndPath}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                       IsVisible="{Binding $parent[UserControl].DataContext.App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=NameOnly}"
                                                       TextWrapping="Wrap" />
                                            <!-- Path — shown in NameAndPath and PathOnly -->
                                            <TextBlock Text="{Binding Path}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"
                                                       IsVisible="{Binding $parent[UserControl].DataContext.App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=NameAndPath}" />
                                            <TextBlock Text="{Binding Path}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"
                                                       IsVisible="{Binding $parent[UserControl].DataContext.App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=PathOnly}" />
                                            <!-- Full URL — shown in FullUrl mode -->
                                            <TextBlock Text="{Binding FullUrl}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"
                                                       IsVisible="{Binding $parent[UserControl].DataContext.App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=FullUrl}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Row 6: Tree view (grouped by path segment) -->
                <ScrollViewer Grid.Row="6" Margin="0,6,0,0"
                              IsVisible="{Binding App.IsCollectionTreeView}">
                    <ItemsControl ItemsSource="{Binding App.CollectionGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CollectionGroupViewModel">
                                <Border Margin="0,2,0,0">
                                    <StackPanel>
                                        <!-- Group header button -->
                                        <Button Command="{Binding ToggleExpandedCommand}"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Padding="4,4"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding IsExpanded, Converter={x:Static convColl:BoolToExpandIconConverter.Instance}}"
                                                           Opacity="0.6" FontSize="10" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding GroupKey}" FontWeight="SemiBold"
                                                           Opacity="0.85" />
                                                <TextBlock Text="{Binding Items.Count, StringFormat='({0})'}"
                                                           Opacity="0.5" FontSize="11" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                        <!-- Group items (collapsible) -->
                                        <ItemsControl ItemsSource="{Binding Items}"
                                                      IsVisible="{Binding IsExpanded}"
                                                      Margin="12,0,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:CollectionItemViewModel">
                                                    <Button Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            Padding="4,3"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Left"
                                                            Command="{Binding $parent[UserControl].DataContext.App.LoadCollectionRequestCommand}"
                                                            CommandParameter="{Binding}">
                                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                                            <TextBlock Text="{Binding Method}"
                                                                       Foreground="{Binding Method, Converter={StaticResource MethodToColorConverter}}"
                                                                       FontWeight="SemiBold" MinWidth="50" />
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                           IsVisible="{Binding $parent[UserControl].DataContext.App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=NameAndPath}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                           IsVisible="{Binding $parent[UserControl].DataContext.App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=NameOnly}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding Path}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"
                                                                           IsVisible="{Binding $parent[UserControl].DataContext.App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=NameAndPath}" />
                                                                <TextBlock Text="{Binding Path}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"
                                                                           IsVisible="{Binding $parent[UserControl].DataContext.App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=PathOnly}" />
                                                                <TextBlock Text="{Binding FullUrl}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"
                                                                           IsVisible="{Binding $parent[UserControl].DataContext.App.CollectionDisplayMode, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=FullUrl}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Scheduled Jobs tab -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" Padding="12" CornerRadius="8"
                IsVisible="{Binding App.LeftPanelTab, Converter={x:Static conv:StringEqualityConverter.Instance}, ConverterParameter=ScheduledJobs}">
            <Grid RowDefinitions="Auto,*">
                <Button Content="{x:Static loc:Strings.LeftPanelAddJob}" Command="{Binding App.AddScheduledJobCommand}" />
                <ScrollViewer Grid.Row="1" Margin="0,6,0,0">
                    <ItemsControl ItemsSource="{Binding App.ScheduledJobs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="scheduledVm:ScheduledJobViewModel">
                                <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4"
                                        Padding="8,6" Margin="0,4,0,0">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="4">
                                        <TextBox PlaceholderText="{x:Static loc:Strings.LeftPanelJobNamePlaceholder}"
                                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                            <ComboBox ItemsSource="{Binding Methods}"
                                                      SelectedItem="{Binding Method, Mode=TwoWay}"
                                                      MinWidth="80" />
                                            <TextBox Grid.Column="1" PlaceholderText="{x:Static loc:Strings.LeftPanelJobUrlPlaceholder}"
                                                     Text="{Binding Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                        <TextBox Grid.Row="2" PlaceholderText="{x:Static loc:Strings.LeftPanelJobBodyPlaceholder}"
                                                 Text="{Binding Body, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                                            <TextBlock Text="{x:Static loc:Strings.LeftPanelIntervalLabel}" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding IntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <CheckBox Grid.Column="2" Content="{x:Static loc:Strings.LeftPanelAutoStart}"
                                                      IsChecked="{Binding AutoStart, Mode=TwoWay}" />
                                        </Grid>
                                        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="16">
                                            <CheckBox Content="{x:Static loc:Strings.LeftPanelJobFollowRedirects}"
                                                      IsChecked="{Binding FollowRedirects, Mode=TwoWay}" />
                                            <!-- "Show in web view" is only meaningful for GET requests that return renderable content -->
                                            <CheckBox Content="{x:Static loc:Strings.LeftPanelJobShowInWebView}"
                                                      IsChecked="{Binding UseWebView, Mode=TwoWay}"
                                                      IsVisible="{Binding IsWebViewApplicable}"
                                                      ToolTip.Tip="After each scheduled tick, open the response URL in the in-app browser window" />
                                        </StackPanel>
                                        <!-- Last response summary — shown only when UseWebView captured at least one response -->
                                        <Border Grid.Row="5"
                                                IsVisible="{Binding HasLastResponse}"
                                                Background="{DynamicResource PreviewPanelBackgroundBrush}"
                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="6,4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Static loc:Strings.LeftPanelJobLastLabel}" Opacity="0.6" FontSize="11" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding LastResponseStatus}"
                                                           FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding LastResponseAtDisplay}"
                                                           Opacity="0.6" FontSize="11" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                        <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="6">
                                            <Button Content="{x:Static loc:Strings.LeftPanelJobStart}"
                                                    Command="{Binding StartCommand}"
                                                    IsEnabled="{Binding !IsRunning}" />
                                            <Button Content="{x:Static loc:Strings.LeftPanelJobStop}"
                                                    Command="{Binding StopCommand}"
                                                    IsEnabled="{Binding IsRunning}" />
                                            <Button Content="{x:Static loc:Strings.LeftPanelJobWebView}"
                                                    AutomationProperties.Name="Open URL in in-app web browser"
                                                    ToolTip.Tip="Open the URL in the in-app web browser"
                                                    IsVisible="{Binding IsWebViewEnabled}"
                                                    Click="OnViewInAppClicked" />
                                            <Button Content="{x:Static loc:Strings.LeftPanelJobDelete}"
                                                    Command="{Binding $parent[UserControl].DataContext.RemoveScheduledJobCommand}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>

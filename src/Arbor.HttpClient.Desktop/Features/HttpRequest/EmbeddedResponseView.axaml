<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:aedit="using:AvaloniaEdit"
             xmlns:webview="using:Avalonia.Controls"
             xmlns:conv="using:Arbor.HttpClient.Desktop.Features.HttpRequest"
             xmlns:loc="using:Arbor.HttpClient.Desktop.Localization"
             x:Class="Arbor.HttpClient.Desktop.Features.HttpRequest.EmbeddedResponseView"
             x:CompileBindings="False">

    <UserControl.Resources>
        <conv:StatusCodeToColorConverter x:Key="StatusCodeToColorConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10" Margin="8" MinHeight="260">

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock Text="{Binding App.ResponseStatus}"
                       Foreground="{Binding App.ResponseStatusCode, Converter={StaticResource StatusCodeToColorConverter}}"
                       FontWeight="SemiBold"
                       AutomationProperties.Name="Response status" />
            <TextBlock Text="{Binding App.ResponseTimeDisplay}"
                       IsVisible="{Binding App.HasResponseHeaders}"
                       Opacity="0.75"
                       AutomationProperties.Name="Response time" />
            <TextBlock Text="{Binding App.ResponseSizeDisplay}"
                       IsVisible="{Binding App.HasResponseHeaders}"
                       Opacity="0.75"
                       AutomationProperties.Name="Response size" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center"
                    IsVisible="{Binding App.IsRequestInProgress}">
            <TextBlock Text="{x:Static loc:Strings.ResponseSendingRequest}" AutomationProperties.Name="Request in progress" />
            <ProgressBar Width="120"
                         IsIndeterminate="True"
                         AutomationProperties.Name="Request in progress indicator" />
        </StackPanel>

        <Grid Grid.Row="2" RowDefinitions="Auto,Auto,*">
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal" Spacing="4"
                        HorizontalAlignment="Right"
                        IsVisible="{Binding App.HasTextResponse}"
                        Margin="0,0,0,4">
                <Button Content="{x:Static loc:Strings.ResponseCopyBody}"
                        AutomationProperties.Name="Copy response body to clipboard"
                        ToolTip.Tip="Copy response body to clipboard"
                        Command="{Binding App.ResponseActions.CopyResponseBodyCommand}" />
                <Button Content="{x:Static loc:Strings.ResponseSaveAsFile}"
                        AutomationProperties.Name="Save response body as file"
                        ToolTip.Tip="Save response body as file"
                        Command="{Binding App.ResponseActions.SaveResponseBodyAsFileCommand}" />
                <Button Content="{x:Static loc:Strings.ResponseCopyAsCurl}"
                        AutomationProperties.Name="Copy current request as cURL"
                        ToolTip.Tip="Copy current request as cURL command"
                        Command="{Binding App.ResponseActions.CopyCurrentRequestAsCurlCommand}" />
            </StackPanel>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" IsVisible="{Binding App.IsBinaryResponse}">
                <TextBlock Text="{x:Static loc:Strings.ResponseBinaryResponse}" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="{x:Static loc:Strings.ResponseSaveAndOpen}"
                        AutomationProperties.Name="Save binary response and open in external application"
                        ToolTip.Tip="Save binary response and open in your default application"
                        Command="{Binding App.ResponseActions.SaveBinaryResponseAndOpenCommand}" />
            </Grid>

            <TabControl Grid.Row="2"
                        SelectedIndex="{Binding App.SelectedResponseTabIndex, Mode=TwoWay}">
                <TabItem Header="{Binding App.ResponseBodyTabLabel}">
                    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <aedit:TextEditor x:Name="ResponseBodyEditor"
                                          ShowLineNumbers="True"
                                          WordWrap="True"
                                          IsReadOnly="True"
                                          MinHeight="200" />
                    </Border>
                </TabItem>
                <TabItem Header="{x:Static loc:Strings.ResponseTabBodyRaw}">
                    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <aedit:TextEditor x:Name="RawResponseBodyEditor"
                                          ShowLineNumbers="True"
                                          WordWrap="True"
                                          IsReadOnly="True"
                                          MinHeight="200" />
                    </Border>
                </TabItem>
                <TabItem Header="{x:Static loc:Strings.ResponseHeadersLabel}">
                    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8,6">
                        <ScrollViewer MaxHeight="260">
                            <ItemsControl ItemsSource="{Binding App.ResponseHeaders}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="{Binding $parent[ItemsControl].DataContext.App.UiFontFamily}"
                                                   FontSize="{Binding $parent[ItemsControl].DataContext.App.UiFontSize}" Opacity="0.9"
                                                   TextWrapping="Wrap" Margin="0,1,0,0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </TabItem>
                <TabItem Header="{x:Static loc:Strings.ResponseTabResponseRaw}">
                    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <aedit:TextEditor x:Name="ResponseRawEditor"
                                          ShowLineNumbers="True"
                                          WordWrap="True"
                                          IsReadOnly="True"
                                          MinHeight="200" />
                    </Border>
                </TabItem>
                <TabItem Header="{x:Static loc:Strings.ResponseTabWebView}">
                    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <webview:NativeWebView x:Name="ResponseWebView"
                                                   IsVisible="{Binding App.IsResponseWebViewAvailable}" />
                            <TextBlock Text="{x:Static loc:Strings.ResponseWebViewUnavailable}"
                                       IsVisible="{Binding !App.IsResponseWebViewAvailable}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0.7"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>

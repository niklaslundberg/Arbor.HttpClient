<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Arbor.HttpClient.Desktop.Features.Cookies"
             xmlns:loc="using:Arbor.HttpClient.Desktop.Localization"
             x:Class="Arbor.HttpClient.Desktop.Features.Cookies.CookieJarView"
             x:DataType="vm:CookieJarViewModel">

    <Grid Margin="12" RowDefinitions="Auto,*,Auto" RowSpacing="10">

        <!-- Header -->
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
            <TextBlock Text="{x:Static loc:Strings.CookieJarTitle}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Content="{x:Static loc:Strings.CookieJarRefresh}"
                    Command="{Binding RefreshCommand}" />
            <Button Grid.Column="2"
                    Content="{x:Static loc:Strings.CookieJarClearAll}"
                    Command="{Binding ClearAllCommand}" />
        </Grid>

        <!-- Cookie list -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Cookies}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CookieEntryViewModel">
                            <Border BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="8,6">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <StackPanel Spacing="2">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="NoWrap" />
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="11"
                                                     Padding="4,2"
                                                     VerticalAlignment="Center" />
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
                                            <TextBlock Text="{Binding Domain}"
                                                       FontSize="11"
                                                       Opacity="0.65" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Expires}"
                                                       FontSize="11"
                                                       Opacity="0.65" />
                                        </Grid>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="🗑"
                                            ToolTip.Tip="Remove cookie"
                                            Command="{Binding $parent[ItemsControl].DataContext.RemoveCommand}"
                                            CommandParameter="{Binding}"
                                            VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Add new cookie -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                <TextBlock Text="{x:Static loc:Strings.CookieJarAddCookieTitle}"
                           FontWeight="SemiBold"
                           FontSize="12" />
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="6">
                    <TextBox PlaceholderText="{x:Static loc:Strings.CookieJarNamePlaceholder}"
                             Text="{Binding NewCookieName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Column="1"
                             PlaceholderText="{x:Static loc:Strings.CookieJarValuePlaceholder}"
                             Text="{Binding NewCookieValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <Grid Grid.Row="2"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="6">
                    <TextBox PlaceholderText="{x:Static loc:Strings.CookieJarDomainPlaceholder}"
                             Text="{Binding NewCookieDomain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Content="{x:Static loc:Strings.CookieJarAddButton}"
                            Command="{Binding AddCookieCommand}" />
                </Grid>
            </Grid>
        </Border>

    </Grid>
</UserControl>
